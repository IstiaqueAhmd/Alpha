    {
      "name": "Catalog — Venues",
      "item": [
        {
          "name": "Search Venues",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/catalog/venues/?q=&radius_miles=&latitude=&longitude=&limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "catalog", "venues", ""],
