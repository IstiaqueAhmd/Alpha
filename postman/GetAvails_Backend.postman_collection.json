            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Daiane Dany\",\n  \"phone\": \"+1 (555) 123-4567\"\n}" },
            "description": "Update name, phone, and avatar (use multipart/form-data with `image` field for file uploads). Only the provided fields are touched."
          }
