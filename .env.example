# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production-please
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (used in prod; dev defaults to sqlite)
DATABASE_URL=postgres://getavails:getavails@db:5432/getavails

# Cache / Redis (prod)
REDIS_URL=redis://redis:6379/0

# JWT
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=1
JWT_REMEMBER_ME_REFRESH_TTL_DAYS=30

# OTP / Password reset
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=GetAvails <no-reply@getavails.com>
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Frontend (used in emails / CORS)
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Google OAuth (frontend obtains ID token, posts it to backend)
GOOGLE_OAUTH_CLIENT_ID=

# Gunicorn (prod)
GUNICORN_WORKERS=3
GUNICORN_THREADS=4
GUNICORN_LOGLEVEL=info
